APP_NAME="Intisari API"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.example.com

# Production Database Configuration
# Replace these placeholders with your actual production credentials.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_production_db
DB_USERNAME=your_database_user
DB_PASSWORD=your_secure_password_here

# Restrict CORS to your actual frontend domain(s). Do not use '*' in production.
CORS_ALLOWED_ORIGINS=https://example.com

AUTH_TOKEN_TTL_MINUTES=1440
AUTH_TOKEN_HASH_ALGO=sha256

# ---------------------------------------------------------
# LOCAL DEVELOPMENT OVERRIDES
# ---------------------------------------------------------
# To run this application locally, comment out the production
# database and CORS settings above, and uncomment the block below:
#
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://127.0.0.1:8000
# DB_CONNECTION=sqlite
# DB_DATABASE=database/api.sqlite
# CORS_ALLOWED_ORIGINS=*
