{
    "name": "lukman-ss/intisari-api",
    "description": "Lightweight RESTful API starter based on IntisariPHP",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "intisari",
        "php",
        "api",
        "rest",
        "starter",
        "lightweight"
    ],
    "require": {
        "php": ">=8.2",
        "lukman-ss/intisari": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8000 -t public",
        "test": "vendor/bin/phpunit",
        "migrate": "php intisari migrate",
        "fresh": "php intisari migrate:fresh",
        "seed": "php intisari db:seed",
        "env:check": "php intisari env:check",
        "source:check": [
            "composer validate --strict",
            "@php scripts/check.php"
        ],
        "docs:check": "@php -r \"foreach(['docs/openapi.yaml','README.md'] as $f)if(!file_exists($f)){echo 'Missing '.$f.PHP_EOL;exit(1);}echo 'Docs OK'.PHP_EOL;\""
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
